# ── VoiceMed Backend environment ──
# Copy this file to ".env" and fill in real values. Never commit the real .env.

# MongoDB connection string (local or Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/voicemed

# Express server port
PORT=5000

# JWT signing secret — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# URL of the Python ML/Whisper service (transcription + NER)
ML_SERVICE_URL=http://localhost:5001

# AES-256 field-level encryption key (32 bytes, hex = 64 chars).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If left blank, field-level encryption is disabled (data stored as plaintext).
FIELD_ENCRYPTION_KEY=

# Secret used to sign emergency QR access tokens
EMERGENCY_QR_SECRET=change-me-emergency-secret

# Public base URL of the frontend (used to build emergency QR links)
FRONTEND_URL=http://localhost:5173
